<section class="rounded-xl border border-slate-800 bg-slate-900/60 p-6">
  <h2 class="text-2xl font-semibold text-slate-100">When to use what</h2>
  <div class="mt-5 grid gap-4 md:grid-cols-3">
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-4">
      <h3 class="font-medium text-slate-100">Build resilient clients</h3>
      <p class="mt-2 text-sm text-slate-400">Use <strong>ffetch</strong> when you need production-safe fetch behavior in app code.</p>
    </div>
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-4">
      <h3 class="font-medium text-slate-100">Inject chaos in tests</h3>
      <p class="mt-2 text-sm text-slate-400">Use <strong>chaos-fetch</strong> when you want fetch-level fault injection in browser or test runtime.</p>
    </div>
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-4">
      <h3 class="font-medium text-slate-100">Chaos at the network edge</h3>
      <p class="mt-2 text-sm text-slate-400">Use <strong>chaos-proxy</strong> when you need transport-level simulation for any HTTP consumer.</p>
    </div>
  </div>
</section>

